# Copy this file to .env.local and fill in your values

# Claude AI API key from https://console.anthropic.com
# Leave empty to run in Demo Mode (simulated data, no real AI calls)
ANTHROPIC_API_KEY=

# Set to "true" to force Demo Mode even if ANTHROPIC_API_KEY is set
# Demo Mode shows a banner and returns pre-filled fixture data for all AI features
DEMO_MODE=true

# Client-readable flag — must match DEMO_MODE above
# Used to show the Demo Mode banner in the browser
NEXT_PUBLIC_DEMO_MODE=true